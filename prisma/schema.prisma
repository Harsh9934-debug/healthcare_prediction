generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id                       String               @id @default(auto()) @map("_id") @db.ObjectId
  name                     String?
  email                    String               @unique
  emailVerified            DateTime?
  image                    String?
  passwordHash             String?
  role                     AppRole              @default(PATIENT)
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  actorAccessAuditLogs     AccessAuditLog[]     @relation("AccessAuditActor")
  ownedAccessAuditLogs     AccessAuditLog[]     @relation("AccessAuditOwner")
  accounts                 Account[]
  generatedAiInsights      AiInsight[]          @relation("AiInsightGeneratedBy")
  ownedAiInsights          AiInsight[]          @relation("AiInsightOwner")
  appointments             Appointment[]
  grantedCareAccessGrants  CareAccess[]         @relation("CareAccessGrantedBy")
  receivedCareAccessGrants CareAccess[]         @relation("CareAccessMember")
  ownedCareAccessGrants    CareAccess[]         @relation("CareAccessOwner")
  sentCareInvites          CareInvite[]         @relation("CareInviteGrantedBy")
  ownedCareInvites         CareInvite[]         @relation("CareInviteOwner")
  deviceConnections        DeviceConnection[]
  deviceReadings           DeviceReading[]
  doctors                  Doctor[]
  healthProfile            HealthProfile?
  labResults               LabResult[]
  documents                MedicalDocument[]
  medications              Medication[]
  medicationLogs           MedicationLog[]
  mobileSessionTokens      MobileSessionToken[]
  reminders                Reminder[]
  sessions                 Session[]
  symptomEntries           SymptomEntry[]
  syncJobs                 SyncJob[]
  vaccinations             VaccinationRecord[]
  vitalRecords             VitalRecord[]
  jobRuns                  JobRun[]
  reminderAuditEntries     ReminderAuditLog[]
  reminderAuditActorLogs   ReminderAuditLog[]   @relation("ReminderAuditActor")
}

model HealthProfile {
  id                    String    @id @default(auto()) @map("_id") @db.ObjectId
  userId                String    @unique @db.ObjectId
  fullName              String
  dateOfBirth           DateTime?
  sex                   Sex?
  bloodType             String?
  heightCm              Float?
  weightKg              Float?
  emergencyContactName  String?
  emergencyContactPhone String?
  chronicConditions     String?
  allergiesSummary      String?
  notes                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Doctor {
  id           String        @id @default(auto()) @map("_id") @db.ObjectId
  userId       String        @db.ObjectId
  name         String
  specialty    String?
  clinic       String?
  phone        String?
  email        String?
  address      String?
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  medications  Medication[]
}

model Medication {
  id           String               @id @default(auto()) @map("_id") @db.ObjectId
  userId       String               @db.ObjectId
  doctorId     String?              @db.ObjectId
  name         String
  dosage       String
  frequency    String
  instructions String?
  startDate    DateTime
  endDate      DateTime?
  status       MedicationStatus     @default(ACTIVE)
  active       Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  doctor       Doctor?              @relation(fields: [doctorId], references: [id])
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs         MedicationLog[]
  schedules    MedicationSchedule[]
}

model MedicationSchedule {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  medicationId String     @db.ObjectId
  timeOfDay    String
  createdAt    DateTime   @default(now())
  medication   Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)
}

model MedicationLog {
  id           String              @id @default(auto()) @map("_id") @db.ObjectId
  userId       String              @db.ObjectId
  medicationId String              @db.ObjectId
  scheduleTime String?
  loggedAt     DateTime            @default(now())
  status       MedicationLogStatus
  notes        String?
  medication   Medication          @relation(fields: [medicationId], references: [id], onDelete: Cascade)
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Appointment {
  id            String            @id @default(auto()) @map("_id") @db.ObjectId
  userId        String            @db.ObjectId
  doctorId      String?           @db.ObjectId
  clinic        String
  specialty     String?
  doctorName    String
  scheduledAt   DateTime
  purpose       String
  notes         String?
  followUpNotes String?
  status        AppointmentStatus @default(UPCOMING)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  doctor        Doctor?           @relation(fields: [doctorId], references: [id])
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LabResult {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String   @db.ObjectId
  testName       String
  dateTaken      DateTime
  resultSummary  String
  referenceRange String?
  flag           LabFlag  @default(NORMAL)
  filePath       String?
  fileName       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VitalRecord {
  id                String        @id @default(auto()) @map("_id") @db.ObjectId
  userId            String        @db.ObjectId
  recordedAt        DateTime      @default(now())
  systolic          Int?
  diastolic         Int?
  heartRate         Int?
  bloodSugar        Float?
  oxygenSaturation  Int?
  temperatureC      Float?
  weightKg          Float?
  notes             String?
  createdAt         DateTime      @default(now())
  externalReadingId String?       @unique
  readingSource     ReadingSource @default(MANUAL)
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, recordedAt])
  @@index([userId, readingSource])
}

model SymptomEntry {
  id        String          @id @default(auto()) @map("_id") @db.ObjectId
  userId    String          @db.ObjectId
  title     String
  severity  SymptomSeverity
  bodyArea  String?
  startedAt DateTime
  duration  String?
  trigger   String?
  notes     String?
  resolved  Boolean         @default(false)
  createdAt DateTime        @default(now())
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VaccinationRecord {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  userId      String    @db.ObjectId
  vaccineName String
  doseNumber  Int
  dateTaken   DateTime
  location    String?
  nextDueDate DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MedicalDocument {
  id        String       @id @default(auto()) @map("_id") @db.ObjectId
  userId    String       @db.ObjectId
  title     String
  type      DocumentType
  filePath  String
  fileName  String
  mimeType  String
  sizeBytes Int
  notes     String?
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Reminder {
  id                 String              @id @default(auto()) @map("_id") @db.ObjectId
  userId             String              @db.ObjectId
  type               ReminderType
  title              String
  description        String?
  dueAt              DateTime
  completed          Boolean             @default(false)
  state              ReminderState       @default(DUE)
  channel            ReminderChannel     @default(IN_APP)
  sentAt             DateTime?
  overdueAt          DateTime?
  skippedAt          DateTime?
  completedAt        DateTime?
  missedAt           DateTime?
  gracePeriodMinutes Int                 @default(60)
  quietHoursStart    String?
  quietHoursEnd      String?
  timezone           String?
  sourceType         ReminderSourceType?
  sourceId           String?
  scheduleId         String?
  dedupeKey          String?             @unique
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  auditLogs          ReminderAuditLog[]

  @@index([userId, dueAt])
  @@index([userId, state, dueAt])
  @@index([userId, type, dueAt])
}

model ReminderAuditLog {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  userId       String    @db.ObjectId
  reminderId   String?   @db.ObjectId
  actorUserId  String?   @db.ObjectId
  action       String
  note         String?
  metadataJson String?
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  reminder     Reminder? @relation(fields: [reminderId], references: [id], onDelete: Cascade)
  actor        User?     @relation("ReminderAuditActor", fields: [actorUserId], references: [id])

  @@index([userId, createdAt])
  @@index([reminderId, createdAt])
}

model CareAccess {
  id                    String           @id @default(auto()) @map("_id") @db.ObjectId
  ownerUserId           String           @db.ObjectId
  memberUserId          String           @db.ObjectId
  accessRole            CareAccessRole
  status                CareAccessStatus @default(ACTIVE)
  canViewRecords        Boolean          @default(true)
  canEditRecords        Boolean          @default(false)
  canAddNotes           Boolean          @default(false)
  canExport             Boolean          @default(false)
  canGenerateAIInsights Boolean          @default(false)
  grantedByUserId       String?          @db.ObjectId
  note                  String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  grantedBy             User?            @relation("CareAccessGrantedBy", fields: [grantedByUserId], references: [id])
  member                User             @relation("CareAccessMember", fields: [memberUserId], references: [id], onDelete: Cascade)
  owner                 User             @relation("CareAccessOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@unique([ownerUserId, memberUserId])
  @@index([memberUserId, status])
}

model CareInvite {
  id                    String           @id @default(auto()) @map("_id") @db.ObjectId
  ownerUserId           String           @db.ObjectId
  email                 String
  accessRole            CareAccessRole
  status                CareAccessStatus @default(PENDING)
  token                 String           @unique
  grantedByUserId       String           @db.ObjectId
  canViewRecords        Boolean          @default(true)
  canEditRecords        Boolean          @default(false)
  canAddNotes           Boolean          @default(false)
  canExport             Boolean          @default(false)
  canGenerateAIInsights Boolean          @default(false)
  note                  String?
  expiresAt             DateTime
  acceptedAt            DateTime?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  grantedBy             User             @relation("CareInviteGrantedBy", fields: [grantedByUserId], references: [id], onDelete: Cascade)
  owner                 User             @relation("CareInviteOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@unique([ownerUserId, email])
  @@index([email, status])
}

model AccessAuditLog {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  ownerUserId  String   @db.ObjectId
  actorUserId  String?  @db.ObjectId
  action       String
  targetType   String?
  targetId     String?
  metadataJson String?
  createdAt    DateTime @default(now())
  actor        User?    @relation("AccessAuditActor", fields: [actorUserId], references: [id])
  owner        User     @relation("AccessAuditOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([ownerUserId, createdAt])
}

model AiInsight {
  id                      String   @id @default(auto()) @map("_id") @db.ObjectId
  ownerUserId             String   @db.ObjectId
  generatedByUserId       String?  @db.ObjectId
  title                   String
  summary                 String
  adherenceRisk           String
  trendFlagsJson          String
  suggestedQuestionsJson  String
  recommendedFollowUpJson String
  disclaimer              String
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  generatedBy             User?    @relation("AiInsightGeneratedBy", fields: [generatedByUserId], references: [id])
  owner                   User     @relation("AiInsightOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([ownerUserId, createdAt])
}

model DeviceConnection {
  id             String                 @id @default(auto()) @map("_id") @db.ObjectId
  userId         String                 @db.ObjectId
  source         ReadingSource
  platform       DevicePlatform
  clientDeviceId String
  deviceLabel    String?
  appVersion     String?
  status         DeviceConnectionStatus @default(ACTIVE)
  scopesJson     String?
  lastSyncedAt   DateTime?
  lastError      String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  readings       DeviceReading[]
  syncJobs       SyncJob[]
  jobRuns        JobRun[]

  @@unique([userId, source, clientDeviceId])
  @@index([userId, source, status])
}

model DeviceReading {
  id             String            @id @default(auto()) @map("_id") @db.ObjectId
  userId         String            @db.ObjectId
  connectionId   String?           @db.ObjectId
  source         ReadingSource
  platform       DevicePlatform
  readingType    DeviceReadingType
  capturedAt     DateTime
  dedupeKey      String            @unique
  unit           String?
  valueInt       Int?
  valueFloat     Float?
  systolic       Int?
  diastolic      Int?
  metadataJson   String?
  rawPayloadJson String?
  createdAt      DateTime          @default(now())
  connection     DeviceConnection? @relation(fields: [connectionId], references: [id])
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, capturedAt])
  @@index([userId, readingType, capturedAt])
  @@index([connectionId, capturedAt])
}

model MobileSessionToken {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  userId     String    @db.ObjectId
  name       String?
  tokenHash  String    @unique
  expiresAt  DateTime
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model SyncJob {
  id             String            @id @default(auto()) @map("_id") @db.ObjectId
  userId         String            @db.ObjectId
  connectionId   String?           @db.ObjectId
  source         ReadingSource
  platform       DevicePlatform
  status         SyncJobStatus     @default(QUEUED)
  requestedCount Int               @default(0)
  acceptedCount  Int               @default(0)
  mirroredCount  Int               @default(0)
  startedAt      DateTime?
  finishedAt     DateTime?
  errorMessage   String?
  metadataJson   String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  connection     DeviceConnection? @relation(fields: [connectionId], references: [id])
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobRuns        JobRun[]

  @@index([userId, createdAt])
  @@index([connectionId, createdAt])
}

model JobRun {
  id           String       @id @default(auto()) @map("_id") @db.ObjectId
  queueName    String
  jobName      String
  jobKind      JobKind
  bullmqJobId  String?      @unique
  status       JobRunStatus @default(QUEUED)
  userId       String?      @db.ObjectId
  connectionId String?      @db.ObjectId
  syncJobId    String?      @db.ObjectId
  inputJson    String?
  resultJson   String?
  errorMessage String?
  attemptsMade Int          @default(0)
  maxAttempts  Int          @default(0)
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user       User?             @relation(fields: [userId], references: [id], onDelete: NoAction)
  connection DeviceConnection? @relation(fields: [connectionId], references: [id], onDelete: NoAction)
  syncJob    SyncJob?          @relation(fields: [syncJobId], references: [id], onDelete: NoAction)
  logs       JobRunLog[]

  @@index([jobKind, createdAt])
  @@index([status, createdAt])
  @@index([userId, createdAt])
  @@index([connectionId, createdAt])
  @@index([syncJobId, createdAt])
}

model JobRunLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  jobRunId    String   @db.ObjectId
  level       String
  message     String
  contextJson String?
  createdAt   DateTime @default(now())
  jobRun      JobRun   @relation(fields: [jobRunId], references: [id], onDelete: Cascade)

  @@index([jobRunId, createdAt])
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum ReminderState {
  DUE
  SENT
  OVERDUE
  SKIPPED
  COMPLETED
  MISSED
}

enum ReminderChannel {
  IN_APP
  EMAIL
  PUSH
}

enum ReminderSourceType {
  MEDICATION_SCHEDULE
  APPOINTMENT
  VACCINATION
  LAB_FOLLOW_UP
  GENERAL
}

enum AppRole {
  PATIENT
  CAREGIVER
  DOCTOR
  LAB_STAFF
  ADMIN
}

enum Sex {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum MedicationStatus {
  ACTIVE
  INACTIVE
  COMPLETED
}

enum MedicationLogStatus {
  TAKEN
  MISSED
  SKIPPED
}

enum AppointmentStatus {
  UPCOMING
  COMPLETED
  CANCELLED
}

enum LabFlag {
  NORMAL
  BORDERLINE
  HIGH
  LOW
}

enum SymptomSeverity {
  MILD
  MODERATE
  SEVERE
}

enum ReminderType {
  MEDICATION
  APPOINTMENT
  VACCINATION
  LAB_FOLLOW_UP
  GENERAL
}

enum DocumentType {
  PRESCRIPTION
  LAB_RESULT
  DISCHARGE_SUMMARY
  CERTIFICATE
  SCAN
  OTHER
}

enum CareAccessRole {
  CAREGIVER
  DOCTOR
  VIEWER
  LAB_STAFF
}

enum CareAccessStatus {
  PENDING
  ACTIVE
  REVOKED
  DECLINED
  EXPIRED
}

enum ReadingSource {
  MANUAL
  ANDROID_HEALTH_CONNECT
  APPLE_HEALTH
  FITBIT
  SMART_BP_MONITOR
  SMART_SCALE
  PULSE_OXIMETER
  OTHER
}

enum DevicePlatform {
  ANDROID
  IOS
  WEB
  OTHER
}

enum DeviceConnectionStatus {
  ACTIVE
  DISCONNECTED
  REVOKED
  ERROR
}

enum SyncJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  PARTIAL
  FAILED
}

enum DeviceReadingType {
  STEPS
  HEART_RATE
  WEIGHT
  BLOOD_PRESSURE
  OXYGEN_SATURATION
  BLOOD_GLUCOSE
  TEMPERATURE
}

enum JobKind {
  ALERT_EVALUATION
  REMINDER_GENERATION
  DAILY_HEALTH_SUMMARY
  DEVICE_SYNC_PROCESSING
}

enum JobRunStatus {
  QUEUED
  ACTIVE
  COMPLETED
  FAILED
  RETRYING
  CANCELLED
}